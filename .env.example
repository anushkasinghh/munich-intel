# Copy to .env and edit values. Defaults work out of the box for local dev.
QDRANT_HOST=localhost
QDRANT_PORT=6333
COLLECTION_NAME=munich_intel
EMBEDDING_MODEL=BAAI/bge-m3
OLLAMA_MODEL=llama3.2:3b
OLLAMA_HOST=http://localhost:11434
LLM_PROVIDER=groq
GROQ_API_KEY=your_key_here
GROQ_MODEL=llama-3.1-8b-instant
CHUNK_SIZE=512
CHUNK_OVERLAP=50
RETRIEVAL_TOP_K=5
